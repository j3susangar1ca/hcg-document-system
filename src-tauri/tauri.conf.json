{
  "productName": "hcg-document-system",
  "version": "0.1.0",
  "identifier": "com.hcg.document-system",
  "build": {
    "beforeDevCommand": "npm --prefix ../src run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../src/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "HCG Document System",
        "width": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
